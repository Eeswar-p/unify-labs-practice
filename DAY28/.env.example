# Example .env file for DAY28
# 
# Copy this to .env and fill in your MongoDB Atlas credentials
# NEVER commit .env to GitHub!

# MongoDB Atlas Connection String (SRV format)
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# 
# Get this from:
# 1. Atlas Dashboard → Clusters → Connect
# 2. Select "Drivers" → Node.js
# 3. Copy the full connection string
# 4. Replace <username> and <password> with your database user credentials
#
# Example:
# MONGO_URL=mongodb+srv://day28_user:MySecurePassword123@cluster0.abcd1234.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Database name (created automatically on first write)
DB_NAME=unify_labs

# Optional: Node environment
NODE_ENV=development

# Optional: Server port
PORT=3028
