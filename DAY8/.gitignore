# ============================================
# PORTFOLIO WEBSITE - .gitignore
# ============================================

# Operating System Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor & IDE Files
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*.swn
*~
.project
.settings/
.classpath

# Node & NPM (if you add build tools later)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.eslintcache

# Environment Variables & Secrets
# ============================================
.env
.env.local
.env.development
.env.production
.env.test
config.local.js
secrets.json

# Build Outputs (if you add build process)
# ============================================
dist/
build/
out/
.next/
.cache/
*.min.css
*.min.js

# Logs & Temporary Files
# ============================================
*.log
logs/
temp/
tmp/
*.tmp
*.bak
*.backup

# Compressed Files (don't commit unless needed)
# ============================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Large Media Files (compress before committing)
# ============================================
# Uncomment if you want to ignore large files
# *.mp4
# *.mov
# *.avi
# *.psd
# *.ai

# Test Files
# ============================================
coverage/
.nyc_output/
*.test.js
*.spec.js

# Misc
# ============================================
.git-credentials
.history/
